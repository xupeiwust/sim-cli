# LAMMPS LJ liquid - minimum viable input
units           lj
atom_style      atomic
dimension       3
boundary        p p p

lattice         fcc 0.8442
region          box block 0 5 0 5 0 5
create_box      1 box
create_atoms    1 box
mass            1 1.0

velocity        all create 1.5 12345 mom yes rot yes

pair_style      lj/cut 2.5
pair_coeff      1 1 1.0 1.0 2.5

fix             1 all nvt temp 1.5 1.5 0.1

thermo          10
run             50
